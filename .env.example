# Copy this file to ".env.local" and paste in your own Supabase project keys.
# Find them in your Supabase dashboard: Project Settings -> API.
# These are the PUBLIC anon keys — safe to use in a client app. Do NOT put the
# "service_role" secret key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
